# InterviewOS — environment variable reference.
# Copy to `.env` at the repo root for docker-compose, and/or into
# backend/.env and frontend/.env.local once those phases exist.
# Never commit a real .env file — it's git-ignored on purpose.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
ENVIRONMENT=development           # development | staging | production
APP_NAME=InterviewOS
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (Phase 4)
# ---------------------------------------------------------------------------
POSTGRES_USER=interviewos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=interviewos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://interviewos:changeme@localhost:5432/interviewos

# ---------------------------------------------------------------------------
# Redis / Celery (Phase 4, Phase 10+)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# Auth (Phase 5)
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=changeme-use-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# Transactional email (Phase 5)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@interviewos.dev

# ---------------------------------------------------------------------------
# AI providers (Phase 10) — provider router picks between these
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_PROVIDER=anthropic      # openai | gemini | anthropic

# ---------------------------------------------------------------------------
# Vector store (Phase 10) — pgvector runs inside the same Postgres instance
# ---------------------------------------------------------------------------
VECTOR_DB_URL=${DATABASE_URL}

# ---------------------------------------------------------------------------
# File storage (Phase 6)
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local               # local | s3
UPLOAD_DIR=./backend/uploads
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Frontend (Phase 3)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
